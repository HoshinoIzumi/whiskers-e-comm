PORT=3000
DATABASE_URL="postgresql://whiskers:whiskers@localhost:5432/whiskers?schema=public"
REDIS_URL="redis://localhost:6379"

JWT_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_DAYS=7

# Square Sandbox (Phase 3) — https://developer.squareup.com/docs/devtools/sandbox/overview
SQUARE_ACCESS_TOKEN=""
SQUARE_LOCATION_ID=""
# Optional: defaults to Sandbox; set to production only when going live
# SQUARE_ENVIRONMENT=sandbox
SQUARE_CURRENCY=USD
# Used for Square Checkout redirect after payment (must match the SPA origin)
FRONTEND_URL=http://localhost:5173
# Webhook signature (Square Developer → Webhooks → subscription signature key)
SQUARE_WEBHOOK_SIGNATURE_KEY=""
# Exact notification URL registered in Square (e.g. https://xxxx.ngrok-free.app/api/orders/webhook)
SQUARE_WEBHOOK_NOTIFICATION_URL=""
